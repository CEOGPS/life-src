{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "checkJs": false,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": [ "esnext", "dom" ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noImplicitAny": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "paths": {
      "@/*": [ "./src/*" ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "esnext",
    "types": [ "vite/client" ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "dist-electron"
  ],
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}